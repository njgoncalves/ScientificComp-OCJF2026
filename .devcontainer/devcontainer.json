{
  "image": "mcr.microsoft.com/devcontainers/python:3.12",
  "forwardPorts": [8888],
  "portsAttributes": {
    "8888": {
      "label": "JupyterLab",
      "onAutoForward": "openBrowser"
    }
  },
  "updateContentCommand": "pip install jupyterlab -r requirements.txt",
  "postAttachCommand": "nohup jupyter lab --ip=0.0.0.0 --no-browser --ServerApp.token='' --ServerApp.password='' --notebook-dir=. > /tmp/jupyterlab.log 2>&1 &",
  "customizations": {
    "vscode": {
      "extensions": ["ms-python.python", "ms-toolsai.jupyter"]
    }
  }
}
